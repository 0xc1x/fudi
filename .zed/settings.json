{
  "context_servers": {
    "github": {
      "command": "node",
      "args": [
        ".ai/mcp/launchers/github.mjs"
      ]
    },
    "supabase-db": {
      "command": "node",
      "args": [
        ".ai/mcp/launchers/supabase-postgres.mjs"
      ]
    },
    "openaiDeveloperDocs": {
      "url": "https://developers.openai.com/mcp"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp"]
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
