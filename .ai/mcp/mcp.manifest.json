{
  "version": 1,
  "name": "fudi-shared-mcp-manifest",
  "envSearchRoots": [
    ".",
    ".ai/mcp"
  ],
  "envFilePriority": [
    ".env",
    ".env.local",
    ".env.mcp",
    ".env.mcp.local",
    ".ai/mcp/.env.mcp.local"
  ],
  "servers": {
    "github": {
      "transport": "stdio",
      "launcher": ".ai/mcp/launchers/github.mjs",
      "requiredEnv": ["GITHUB_PERSONAL_ACCESS_TOKEN"],
      "runtimeEnv": ["GITHUB_ACCESS_TOKEN"],
      "package": "github-mcp",
      "enabledByDefault": true
    },
    "supabase-db": {
      "transport": "stdio",
      "launcher": ".ai/mcp/launchers/supabase-postgres.mjs",
      "requiredEnv": ["SUPABASE_DB_URL"],
      "runtimeEnv": ["DB_MAIN_URL", "DB_ALIASES", "DEFAULT_DB_ALIAS"],
      "package": "postgres-mcp",
      "enabledByDefault": true
    },
    "openaiDeveloperDocs": {
      "transport": "http",
      "url": "https://developers.openai.com/mcp",
      "requiredEnv": [],
      "enabledByDefault": true
    },
    "react-docs": {
      "transport": "http",
      "url": "https://react.dev/learn",
      "requiredEnv": [],
      "enabledByDefault": true,
      "description": "Documentación oficial de React para análisis de código existente"
    },
    "flutter-docs": {
      "transport": "http",
      "url": "https://docs.flutter.dev",
      "requiredEnv": [],
      "enabledByDefault": true,
      "description": "Documentación oficial de Flutter para desarrollo y migración"
    },
    "flutter-testing": {
      "transport": "http",
      "url": "https://docs.flutter.dev/cookbook/testing",
      "requiredEnv": [],
      "enabledByDefault": true,
      "description": "Documentación de testing específico de Flutter"
    },
    "jest-docs": {
      "transport": "http",
      "url": "https://jestjs.io/docs/getting-started",
      "requiredEnv": [],
      "enabledByDefault": true,
      "description": "Documentación de Jest para entender patrones de testing React"
    },
    "github-actions": {
      "transport": "http",
      "url": "https://docs.github.com/en/actions",
      "requiredEnv": [],
      "enabledByDefault": true,
      "description": "Documentación de GitHub Actions para CI/CD"
    },
    "figma-api": {
      "transport": "stdio",
      "launcher": ".ai/mcp/launchers/figma.mjs",
      "requiredEnv": ["FIGMA_ACCESS_TOKEN"],
      "runtimeEnv": ["FIGMA_API_KEY"],
      "package": "figma-mcp",
      "enabledByDefault": false,
      "description": "API de Figma para extraer designs y componentes"
    },
    "linear": {
      "transport": "stdio",
      "launcher": ".ai/mcp/launchers/linear.mjs",
      "requiredEnv": ["LINEAR_API_KEY"],
      "package": "@mseep/linear-mcp",
      "enabledByDefault": false,
      "description": "Integration con Linear para gestión de tareas"
    }
  }
}
