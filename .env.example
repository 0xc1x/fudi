# Fudi environment configuration template
# Copy this file to .env.dev / .env.staging / .env.prod and fill in values.
# NEVER commit real secrets to version control.

# App environment (resolved at compile time via --dart-define=APP_ENV=dev)
# This is informational — the actual env file loaded is determined by APP_ENV.
APP_ENV=dev

SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SENTRY_DSN=your_sentry_dsn
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
AUTH_RESET_REDIRECT_URL=fudi://auth/update-password

# Firebase (optional — analytics will be no-op if not configured)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id

PTP_WEBHOOK_SECRET=your_place_to_pay_webhook_secret
PLATFORM_FEE_PCT=10
PAYOUT_SCHEDULE=weekly
FIREBASE_VAPID_KEY=key
