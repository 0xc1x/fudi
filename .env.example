# Fudi environment configuration template
# Copy this file to .env.dev / .env.staging / .env.prod and fill in values.
# NEVER commit real secrets to version control.

# App environment (resolved at compile time via --dart-define=APP_ENV=dev)
# This is informational — the actual env file loaded is determined by APP_ENV.
APP_ENV=dev

SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SENTRY_DSN=your_sentry_dsn
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
