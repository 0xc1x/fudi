# Copy this file to .env.mcp.local and fill real values.
# These values are consumed by the shared MCP launchers in .ai/mcp/launchers/.

# Required by the GitHub MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=

# Required by the Supabase / Postgres MCP server
# Example:
# postgresql://postgres:password@db.example.supabase.co:5432/postgres
SUPABASE_DB_URL=

# Optional future MCPs
GOOGLE_MAPS_API_KEY=
SENTRY_AUTH_TOKEN=
CONTEXT7_API_KEY=
